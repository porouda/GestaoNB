<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema de Gestão de Treinamentos</title>
    <link rel="stylesheet" href="css/styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>

    <div class="sidebar" id="sidebar">
        <!-- Menu will be loaded via script.js -->
    </div>

    <div class="main-content">
        <header class="page-header">
            <h1 class="page-title">Dashboard</h1>
        </header>

        <div class="bento-grid" id="dashboard-grid">
            <!-- Saudação e Data (Card Superior) -->
            <div class="container-full" style="grid-column: span 3; display: flex; justify-content: space-between; align-items: center; background: linear-gradient(135deg, var(--primary-color) 0%, #1e293b 100%); color: white; border: none; padding: 15px 25px;">
                <div>
                    <h2 id="dash-saudacao" style="font-size: 1.3rem; font-weight: 800; margin-bottom: 2px;">Boa tarde, ...</h2>
                    <p style="opacity: 0.8; font-size: 0.85rem;">Bem-vindo ao centro de operações NorthBrasil.</p>
                </div>
                <div id="dash-data-atual" style="text-align: right; background: rgba(255,255,255,0.1); padding: 8px 20px; border-radius: 14px; backdrop-filter: blur(10px);">
                    <span id="dash-dia" style="display: block; font-size: 1.8rem; font-weight: 900; line-height: 1;">18</span>
                    <span id="dash-mes-ano" style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; opacity: 0.7;">ABRIL, 2026</span>
                </div>
            </div>

            <!-- Resumo do Mês (Card 1) -->
            <div class="container-full" style="grid-column: span 1; padding: 15px;">
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
                    <div style="width: 38px; height: 38px; background: #eff6ff; color: #3b82f6; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1rem;">
                        <i class="fas fa-calendar-check"></i>
                    </div>
                    <h3 style="font-size: 0.9rem; font-weight: 700; color: var(--text-main);">Treinamentos no Mês</h3>
                </div>
                <div style="text-align: center;">
                    <span id="dash-count-mes" style="font-size: 2.5rem; font-weight: 900; color: var(--primary-color); display: block; line-height: 1;">0</span>
                    <span style="font-size: 0.75rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase;">Eventos Confirmados</span>
                </div>
            </div>

            <!-- Próximos 10 Treinamentos (Span 2) -->
            <div class="container-full" style="grid-column: span 2; grid-row: span 2; padding: 15px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                    <h3 style="font-size: 0.95rem; font-weight: 700; color: var(--primary-color);"><i class="fas fa-list-ul" style="margin-right: 8px; color: var(--accent-color);"></i> Próximos 10 Treinamentos</h3>
                    <a href="consulta-treinamentos.html" style="font-size: 0.75rem; color: var(--accent-color); text-decoration: none; font-weight: 700;">Ver todos <i class="fas fa-chevron-right" style="font-size: 0.65rem;"></i></a>
                </div>
                <div id="dash-proximos-treinamentos" style="display: flex; flex-direction: column; gap: 6px;">
                    <!-- Carregado via JS -->
                    <p style="color: var(--text-muted); font-size: 0.9rem; text-align: center; padding: 20px;">Carregando agenda...</p>
                </div>
            </div>

            <!-- Alertas de Estoque (Card Pequeno) -->
            <div class="container-full" style="grid-column: span 1; padding: 15px;">
                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px;">
                    <div style="width: 32px; height: 32px; background: #fff1f2; color: #e11d48; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 0.9rem;">
                        <i class="fas fa-exclamation-triangle"></i>
                    </div>
                    <h3 style="font-size: 0.85rem; font-weight: 700; color: #9f1239;">Alertas de Estoque</h3>
                </div>
                <div id="dash-estoque-alerts" style="display: flex; flex-direction: column; gap: 8px;">
                    <!-- Carregado via JS -->
                    <p style="font-size: 0.8rem; color: var(--text-muted);">Verificando estoque...</p>
                </div>
                <a href="estoque.html" style="display: block; margin-top: 10px; font-size: 0.7rem; font-weight: 700; color: #e11d48; text-decoration: none; text-align: center; padding: 6px; border: 1px solid #fee2e2; border-radius: 8px;">Gerenciar Estoque</a>
            </div>
        </div>
    </div>
    </div>

    <script type="module" src="js/auth-check.js"></script>
    <script type="module" src="js/script.js"></script>
</body>
</html>